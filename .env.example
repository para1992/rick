# Copy to .env for local real-model runs.
# Leave OPENROUTER_API_KEY empty to use Rick's local mock client.
OPENROUTER_API_KEY=

# Default model tier configuration. Override these with models available to your account.
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_MODEL_LOW=openrouter/free
OPENROUTER_MODEL_MEDIUM=google/gemini-2.0-flash-001
OPENROUTER_MODEL_HIGH=google/gemini-3.1-flash-lite-preview

# Optional OpenRouter request metadata.
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_SITE_NAME=Rick

# Optional runtime knobs.
RICK_MAX_CALLS=60
OPENROUTER_MAX_RETRIES=3
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_BACKOFF_SECONDS=1
